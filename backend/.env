# backend/.env

# Base de datos
DATABASE_URL=sqlite:///./netpolix.db
# Para PostgreSQL sería: postgresql://usuario:contraseña@localhost:5432/netpolix

# JWT - Esta clave debe ser larga y aleatoria. Genera una con:
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=tu_clave_secreta_muy_larga_aqui_generala_con_el_comando_de_arriba
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Entorno
ENVIRONMENT=development